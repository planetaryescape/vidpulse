{
  "name": "vidpulse",
  "version": "1.3.0",
  "description": "AI-powered YouTube video analysis - know if it's worth your time before watching",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "bun scripts/release.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@crxjs/vite-plugin": "^2.3.0",
    "@preact/preset-vite": "^2.10.2",
    "@types/chrome": "^0.1.32",
    "@types/dompurify": "^3.2.0",
    "canvas": "^3.2.0",
    "lefthook": "^2.0.13",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^3.1.4",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^1.5.4",
    "@openrouter/sdk": "^0.3.12",
    "ai": "^5.0.119",
    "chart.js": "^4.5.1",
    "dompurify": "^3.3.1",
    "marked": "^17.0.1",
    "preact": "^10.28.2"
  }
}
